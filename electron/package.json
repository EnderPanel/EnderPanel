{
  "name": "enderpanel-app",
  "version": "1.0.1",
  "description": "EnderPanel - Minecraft Server Management",
  "homepage": "https://enderpanel.space",
  "author": {
    "name": "ThatMacOSGuy & carit1",
    "email": "thatmacosguy@outlook.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.enderpanel.app",
    "productName": "EnderPanel",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "identity": null,
      "hardenedRuntime": false
    },
    "win": {
      "icon": "icon.png",
      "target": ["nsis", "zip"]
    },
    "linux": {
      "icon": "icon.png",
      "target": ["AppImage"]
    },
    "files": ["main.js", "preload.js", "setup.html", "icon.png"]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
